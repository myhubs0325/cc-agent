+def _split_ai_model_channel_and_key(raw_value: Any) -> tuple[str, str]:
+    value = str(raw_value or "").strip()
+    if not value:
+        return "", ""
+    channel, separator, remainder = value.partition(" ")
+    if separator and remainder.strip():
+        return channel.strip(), remainder.strip()
+    return "", value
