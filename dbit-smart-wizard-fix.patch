+    def _ensure_control_panel_authorized(
+        self,
+        username: str = "",
+        password: str = "",
+        *,
+        timeout_seconds: float | None = None,
+    ) -> tuple[bool, dict[str, Any]]:
+        token = self._current_control_panel_token()
+        if token:
+            payload = self._verify_control_panel_token(token, timeout_seconds=timeout_seconds)
+            if payload is not None:
+                return True, {"control_panel_authorized": True, "control_panel_auth_source": "token"}
+
+        if username and password:
+            try:
+                payload = self._login_control_panel_with_credentials(username, password, timeout_seconds=timeout_seconds)
+            except Exception as exc:
+                return False, {"control_panel_authorized": False, "control_panel_auth_error": str(exc)}
+            token = self._current_control_panel_token()
+            if token and self._verify_control_panel_token(token, timeout_seconds=timeout_seconds) is not None:
+                data = payload.get("data", {}) if isinstance(payload, dict) else {}
+                user = data.get("user", {}) if isinstance(data, dict) else {}
+                return True, {
+                    "control_panel_authorized": True,
+                    "control_panel_auth_source": "mock_login",
+                    "control_panel_user": str(user.get("username", "") or "").strip(),
+                }
+
+        return False, {"control_panel_authorized": False}
+
+    def _login_control_panel_with_credentials(
+        self,
+        username: str,
+        password: str,
+        *,
+        timeout_seconds: float | None = None,
+    ) -> dict[str, Any]:
+        base_url = str(self._config.get("control_panel_base_url", "")).strip()
+        if not base_url:
+            raise ValueError("DBIt 未配置 control_panel_base_url。")
+        timeout = timeout_seconds if timeout_seconds is not None else float(self._config.get("control_panel_timeout_seconds", 5))
+        with httpx.Client(timeout=timeout, trust_env=False) as client:
+            response = client.post(
+                f"{base_url.rstrip('/')}/api/auth/mock-login",
+                json={"username": username, "password": password},
+            )
+        response.raise_for_status()
+        payload = response.json()
+        if isinstance(payload, dict) and payload.get("success") is False:
+            raise PermissionError(str(payload.get("message", "")).strip() or "DBIt mock-login failed")
+        data = payload.get("data", {}) if isinstance(payload, dict) else {}
+        token = str(data.get("accessToken", "") or "").strip() if isinstance(data, dict) else ""
+        if not token and isinstance(payload, dict):
+            token = str(payload.get("accessToken", "") or "").strip()
+        if not token:
+            raise PermissionError("DBIt mock-login 未返回 accessToken。")
+        self._control_panel_token_override = token
+        return payload if isinstance(payload, dict) else {}
+
+    def _verify_control_panel_token(
+        self,
+        token: str,
+        *,
+        timeout_seconds: float | None = None,
+    ) -> dict[str, Any] | None:
+        base_url = str(self._config.get("control_panel_base_url", "")).strip()
+        if not base_url or not token:
+            return None
+        timeout = timeout_seconds if timeout_seconds is not None else float(self._config.get("control_panel_timeout_seconds", 5))
+        try:
+            with httpx.Client(timeout=timeout, trust_env=False) as client:
+                response = client.get(
+                    f"{base_url.rstrip('/')}/api/auth/verify-token",
+                    headers={"Authorization": f"Bearer {token}"},
+                    params={"authToken": token},
+                )
+        except Exception:
+            return None
+        if response.status_code in (401, 403):
+            return None
+        try:
+            payload = response.json()
+        except Exception:
+            return None
+        if not isinstance(payload, dict) or payload.get("success") is False:
+            return None
+        return payload
+
+    def _clear_stale_auth_expired_log(self) -> Path | None:
+        auth_log_path = self._system_auth_log_path()
+        if auth_log_path is None or not auth_log_path.exists():
+            return None
+        try:
+            text = auth_log_path.read_text(encoding="utf-8", errors="ignore")
+        except Exception:
+            return None
+        if "AUTH_EXPIRED" not in text:
+            return None
+        backup_dir = self._screenshots_dir.parent / "tmp_dbit_recovery"
+        backup_dir.mkdir(parents=True, exist_ok=True)
+        backup_path = backup_dir / f"system_0_auth_expired_backup_{int(time.time())}.log"
+        try:
+            backup_path.write_text(text, encoding="utf-8")
+            auth_log_path.write_text("", encoding="utf-8")
+        except Exception:
+            return None
+        return backup_path
+
+    def _system_auth_log_path(self) -> Path | None:
+        executable_path = self._resolved_executable_path()
+        install_root = executable_path.parent if executable_path.suffix.casefold() == ".exe" else executable_path
+        auth_log_path = install_root / "data" / "instance-logs" / "system_0.log"
+        return auth_log_path if auth_log_path.exists() else None
+
+    def _extract_control_panel_token(self) -> str:
+        token_store_path = Path(str(self._config.get("token_store_path", "")).strip())
+        if not token_store_path.exists():
+            return ""
+        try:
+            text = token_store_path.read_bytes().decode("utf-8", errors="ignore")
+        except Exception:
+            return ""
+
+        import re
+
+        token = ""
+        pattern = re.compile(r"([A-Za-z0-9+/=_-]{80,}\.[A-Za-z0-9+/=_-]{80,})")
+        for match in pattern.finditer(text):
+            token = match.group(1)
+        return token
+
+    def _is_control_panel_shell_ready(self, *, timeout_seconds: float | None = None) -> bool:
+        base_url = str(self._config.get("control_panel_base_url", "")).strip()
+        if not base_url:
+            return False
+        timeout = timeout_seconds if timeout_seconds is not None else float(self._config.get("control_panel_timeout_seconds", 5))
+        try:
+            with httpx.Client(timeout=timeout, trust_env=False) as client:
+                response = client.get(f"{base_url.rstrip('/')}/")
+            return response.status_code == 200
+        except Exception:
+            return False
+
