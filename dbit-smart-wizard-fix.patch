+            control_type = self._dbit_control_type(control)
+            if control_type not in {"Edit", "Document", "Pane", "ComboBox"}:
+                continue
+            rect = self._dbit_control_rect(control)
+            if rect is None or not self._looks_like_dbit_login_input(rect, window_rect):
+                continue
+            identity = (control_type, rect)
+            if identity in seen:
+                continue
+            seen.add(identity)
+            candidates.append(
+                {
+                    "control": control,
+                    "rect": rect,
+                    "control_type": control_type,
+                    "hints": self._dbit_control_hints(control),
+                }
+            )
+        return candidates
