+def _platform_display_name(platform: str) -> str:
+    normalized = _normalize_platform(platform)
+    if normalized == "facebook":
+        return "Facebook"
+    return "TikTok" if normalized == "tiktok" else (str(platform or "").strip() or "目标平台")
+
+
+def _platform_locator_tokens(platform: str) -> list[str]:
+    normalized = _normalize_platform(platform)
+    if normalized == "facebook":
+        return list(DEFAULT_LOCATORS["facebook_tokens"])
+    return list(DEFAULT_LOCATORS["tiktok_tokens"])
+
+
+def _platform_control_types(platform: str) -> list[str]:
+    normalized = _normalize_platform(platform)
+    if normalized == "facebook":
+        return list(DEFAULT_LOCATORS["facebook_control_types"])
+    return list(DEFAULT_LOCATORS["tiktok_control_types"])
+
+
+def _platform_from_tokens(tokens: list[str]) -> str:
+    lowered = {str(token).casefold() for token in tokens if token}
+    if lowered & {token.casefold() for token in DEFAULT_LOCATORS["facebook_tokens"]}:
+        return "facebook"
+    if lowered & {token.casefold() for token in DEFAULT_LOCATORS["tiktok_tokens"]}:
+        return "tiktok"
+    return ""
+
