+    def _paste_text_into_focused_control(self, value: str) -> bool:
+        if not self._set_windows_clipboard_text(value):
+            return False
+        try:
+            self._ui_driver.send_keys("^a{BACKSPACE}")
+            time.sleep(0.05)
+        except Exception:
