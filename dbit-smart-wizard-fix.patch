+    def _submit_login_form(
+        self,
+        window: BaseWrapper,
+        flow_step: dict[str, Any],
+        *,
+        username: str,
+        password: str,
+        max_depth: int,
+        max_nodes: int,
+    ) -> str:
+        username_labels = flow_step.get("username_labels") or ["账号", "用户名", "Account", "Username"]
+        password_labels = flow_step.get("password_labels") or ["密码", "Password"]
+        username_filled = False
+        password_filled = False
+
+        try:
+            self._ui_driver.fill_labeled_input(
+                window,
+                labels=username_labels,
+                value=username,
+                max_depth=max_depth,
+                max_nodes=max_nodes,
+                skip_child_classes=self._webview_skip_classes(),
+            )
+            username_filled = True
+        except Exception:
+            pass
+        try:
+            self._ui_driver.fill_labeled_input(
+                window,
+                labels=password_labels,
+                value=password,
+                max_depth=max_depth,
+                max_nodes=max_nodes,
+                skip_child_classes=self._webview_skip_classes(),
+            )
+            password_filled = True
+        except Exception:
+            pass
+
+        username_control = None
+        password_control = None
+        if not username_filled or not password_filled:
+            username_control, password_control = self._find_dbit_login_field_controls(
+                window,
+                flow_step,
+                max_depth=max_depth,
+                max_nodes=max_nodes,
+            )
+            if not username_filled and username_control is not None:
+                username_filled = self._set_dbit_login_input_value(username_control, username)
+            if not password_filled and password_control is not None:
+                password_filled = self._set_dbit_login_input_value(password_control, password)
+            if username_filled and not password_filled and username_control is not None:
+                try:
+                    self._ui_driver.send_keys("{TAB}")
+                    time.sleep(0.1)
+                    password_filled = self._paste_text_into_focused_control(password)
+                except Exception:
+                    password_filled = False
+
+        if not username_filled or not password_filled:
+            raise ValueError("未能稳定定位 DBit 登录输入框。")
+
+        login_button = self._find_login_submission_control(window, flow_step, max_depth=max_depth, max_nodes=max_nodes)
+        if login_button is None:
+            clicked_text = self._submit_dbit_login_without_visible_button(window, password_control=password_control)
+            if clicked_text:
+                return clicked_text
+            raise ValueError("未找到登录提交按钮。")
+        clicked_text = self._activate_dbit_login_control(login_button)
+        return clicked_text or self._ui_driver.read_text(login_button) or "login_submit"
+
