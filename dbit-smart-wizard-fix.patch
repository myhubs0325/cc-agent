+    def _supports_control_panel_named_control(tokens: list[str]) -> bool:
+        lowered = {str(token).casefold() for token in tokens if token}
+        return bool(lowered & {token.casefold() for token in DEFAULT_LOCATORS["system_config_tokens"]})
