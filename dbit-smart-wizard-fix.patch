+        replacement_profile_id = str(replacement.get("profileId", "") or "").strip()
+        replacement_name = str(replacement.get("name", "") or "").strip()
+        updated_bucket: list[dict[str, Any]] = []
+        for item in bucket:
+            item_id = item.get("id")
+            item_profile_id = str(item.get("profileId", "") or "").strip()
+            item_name = str(item.get("name", "") or "").strip()
+            if (
