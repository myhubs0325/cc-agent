+    ) -> tuple[BaseWrapper | None, BaseWrapper | None]:
+        candidates = self._collect_dbit_login_input_candidates(window, max_depth=max_depth, max_nodes=max_nodes)
+        if not candidates:
+            return None, None
+        username_control = self._select_best_dbit_login_field_control(
+            candidates,
+            role="username",
