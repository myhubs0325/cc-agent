+    def _save_all_instances_via_control_panel(self, instances_payload: dict[str, Any]) -> dict[str, list[dict[str, Any]]]:
+        payload = self._control_panel_request("POST", "/api/save-instances", json_body=instances_payload)
+        data = payload.get("data", {})
+        if not isinstance(data, dict):
+            raise ValueError("DBit control panel save-instances 未返回可用 data。")
+        normalized: dict[str, list[dict[str, Any]]] = {}
+        for key in ("linkedin", "facebook", "tiktok"):
+            bucket = data.get(key, [])
+            normalized[key] = [item for item in bucket if isinstance(item, dict)] if isinstance(bucket, list) else []
+        return normalized
+
+    def _control_panel_request(
+        self,
+        method: str,
+        path: str,
+        *,
+        json_body: dict[str, Any] | None = None,
+    ) -> dict[str, Any]:
+        base_url = str(self._config.get("control_panel_base_url", "")).strip()
+        token = self._current_control_panel_token()
+        if not base_url:
+            raise ValueError("DBIt 未配置 control_panel_base_url。")
+        if not token:
+            raise PermissionError("DBIt 本地控制面板 token 不可用。")
+        timeout = float(self._config.get("control_panel_timeout_seconds", 5))
+        with httpx.Client(timeout=timeout, trust_env=False) as client:
+            response = client.request(
+                method=method.upper(),
+                url=f"{base_url.rstrip('/')}{path}",
+                headers={"Authorization": f"Bearer {token}"},
+                params={"authToken": token},
+                json=json_body,
+            )
+        if response.status_code in (401, 403):
+            raise PermissionError(f"DBIt 本地控制面板未授权：HTTP {response.status_code}")
+        response.raise_for_status()
+        payload = response.json()
+        if isinstance(payload, dict) and payload.get("success") is False:
+            raise ValueError(str(payload.get("message", "")).strip() or "DBIt control panel returned failure")
+        return payload if isinstance(payload, dict) else {}
+
+    def _merge_control_panel_system_settings(
+        self,
+        current_settings: dict[str, Any],
+        payload: dict[str, Any],
+    ) -> dict[str, Any]:
+        merged = dict(current_settings)
+        dbit = payload.get("dbit", {})
+        ai_model_channel, ai_model_api_key = _split_ai_model_channel_and_key(dbit.get("ai_model_api_key", ""))
+        if ai_model_api_key:
+            merged["apiKey"] = ai_model_api_key
+        merged["model"] = _control_panel_model_from_channel(ai_model_channel, str(merged.get("model", "") or ""))
+        return merged
+
+    def _ensure_control_panel_clone_instance(
+        self,
+        instances_payload: dict[str, list[dict[str, Any]]],
+        platform: str,
+        clone_config: dict[str, Any],
+    ) -> tuple[dict[str, Any], dict[str, list[dict[str, Any]]], bool]:
+        normalized_platform = _normalize_platform(platform) or "tiktok"
+        profile_id = str(clone_config.get("adspower_profile_id", "") or "").strip()
+        clone_name = str(clone_config.get("clone_name", "") or "").strip()
+        bucket = [dict(item) for item in instances_payload.get(normalized_platform, [])]
+        instance = self._locate_platform_instance(bucket, None, profile_id, clone_name)
+        created = False
+        if instance is None:
+            created = True
+            candidate = {
+                "id": _next_control_panel_instance_id(bucket),
+                "profileId": profile_id,
+                "name": clone_name or f"{_platform_display_name(normalized_platform)}-{len(bucket) + 1:02d}",
+                "status": "offline",
+                "loading": False,
+            }
+            bucket.append(candidate)
+            instances_payload = {**instances_payload, normalized_platform: bucket}
+            saved_instances = self._save_all_instances_via_control_panel(instances_payload)
+            saved_bucket = saved_instances.get(normalized_platform, [])
+            instance = self._locate_platform_instance(saved_bucket, candidate["id"], profile_id, candidate["name"])
+            if self._instance_has_usable_control_panel_config(instance, normalized_platform):
+                return dict(instance), saved_instances, created
+            refreshed_instances = self._refresh_control_panel_created_instance(
+                normalized_platform,
+                candidate["id"],
+                profile_id,
+                candidate["name"],
+                fallback_instances=saved_instances,
+            )
+            refreshed_bucket = refreshed_instances.get(normalized_platform, [])
+            refreshed_instance = self._locate_platform_instance(
+                refreshed_bucket,
+                candidate["id"],
+                profile_id,
+                candidate["name"],
+            )
+            if refreshed_instance is not None:
+                return dict(refreshed_instance), refreshed_instances, created
+            return dict(instance or candidate), saved_instances, created
+        return dict(instance), instances_payload, created
