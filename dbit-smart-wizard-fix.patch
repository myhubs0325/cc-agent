+    def _score_dbit_login_field_candidate(
+        self,
+        candidate: dict[str, Any],
+        *,
+        role: str,
+        labels: Iterable[str],
+    ) -> int:
+        rect = candidate["rect"]
+        hints = " ".join(candidate["hints"]).casefold()
+        control_type = str(candidate["control_type"] or "")
+        top = rect[1]
+        height = max(rect[3] - rect[1], 1)
+        score = 0
+
+        if control_type == "Edit":
+            score += 8
+        elif control_type == "ComboBox":
+            score += 6
+        elif control_type == "Document":
+            score += 5
+        elif control_type == "Pane":
+            score += 3
+        if 20 <= height <= 72:
+            score += 3
+
+        label_tokens = self._dbit_text_tokens([labels])
+        password_tokens = self._dbit_text_tokens([["密码", "Password", "Passcode"]])
+        if role == "password":
+            if any(token.casefold() in hints for token in label_tokens):
+                score += 14
+            if any(token.casefold() in hints for token in ("password", "密码", "passcode")):
+                score += 6
+        else:
+            if any(token.casefold() in hints for token in label_tokens):
+                score += 14
+            if any(token in hints for token in ("account", "username", "账号", "用户名")):
+                score += 6
+            if any(token.casefold() in hints for token in password_tokens):
+                score -= 12
+            if top > 0:
+                score += 4 if top < 500 else 1
+        return score
+
+    def _set_dbit_login_input_value(self, control: BaseWrapper, value: str) -> bool:
+        if not str(value).strip():
