+def _normalize_platform(value: Any) -> str:
+    normalized = str(value or "").strip().casefold()
+    if normalized in {"tiktok", "tik tok", "tiki tok"}:
+        return "tiktok"
+    if normalized in {"facebook", "facebook ", "face book", "face-book", "fb", "facebok", "face book"}:
+        return "facebook"
+    return normalized
