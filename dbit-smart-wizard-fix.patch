+            exclude=username_control,
+        )
+        ordered_candidates = sorted(candidates, key=lambda item: (item["rect"][1], item["rect"][0]))
+        if username_control is None and ordered_candidates:
+            username_control = ordered_candidates[0]["control"]
+        if password_control is None:
+            username_top = None
+            if username_control is not None:
