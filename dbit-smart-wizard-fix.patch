+    def _select_best_dbit_login_field_control(
+        self,
+        candidates: list[dict[str, Any]],
+        *,
+        role: str,
+        labels: Iterable[str],
+        exclude: BaseWrapper | None = None,
+    ) -> BaseWrapper | None:
+        best_control = None
+        best_score = 0
+        for candidate in candidates:
+            control = candidate["control"]
+            if exclude is not None and self._dbit_controls_match(control, exclude):
+                continue
+            score = self._score_dbit_login_field_candidate(candidate, role=role, labels=labels)
+            if score > best_score:
+                best_score = score
+                best_control = control
+        return best_control
