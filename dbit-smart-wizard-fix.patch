+    @staticmethod
+    def _is_installer_title(title: str) -> bool:
+        lowered = str(title or "").strip().casefold()
+        if not lowered:
+            return False
+        if "setup - dbit-octopus version" in lowered:
+            return True
+        product_tokens = ("dbit-octopus", "dbit octopus", "dbitoct")
+        installer_tokens = ("setup", "installer", "installation", "install", "wizard", "安装", "卸载", "uninstall")
+        return any(token in lowered for token in product_tokens) and any(token in lowered for token in installer_tokens)
