+            max_depth=max_depth,
+            max_nodes=max_nodes,
+        )
+        password_rect = self._dbit_control_rect(password_control) if password_control is not None else None
+        for control in self._ui_driver.iter_controls(
+            window,
+            max_depth=max(max_depth, 16),
+            max_nodes=max(max_nodes, 1200),
+            max_seconds=4.0,
+            skip_child_classes=[],
+        ):
+            control_type = self._dbit_control_type(control)
+            if control_type not in {"Button", "Hyperlink", "Text", "Document", "Pane"}:
+                continue
+            rect = self._dbit_control_rect(control)
+            if rect is None or not self._looks_like_dbit_submit_region(rect, window_rect, password_rect):
+                continue
+            hints = self._dbit_control_hints(control)
+            score = self._score_dbit_login_submit_candidate(
+                rect=rect,
+                hints=hints,
+                control_type=control_type,
+                password_rect=password_rect,
+                window_rect=window_rect,
+                login_tokens=flow_step.get("login_tokens") or ["登录我的AI获客控制台", "登录", "Login", "Sign in"],
+            )
+            if score <= 0:
+                continue
+            candidates.append({"control": control, "score": score, "rect": rect})
+        if not candidates:
+            return None
+        candidates.sort(key=lambda item: (item["score"], -item["rect"][1]), reverse=True)
+        return candidates[0]["control"]
+
+    def _score_dbit_login_submit_candidate(
+        self,
+        *,
+        rect: tuple[int, int, int, int],
+        hints: list[str],
+        control_type: str,
+        password_rect: tuple[int, int, int, int] | None,
+        window_rect: tuple[int, int, int, int] | None,
+        login_tokens: Iterable[str],
+    ) -> int:
+        left, top, right, bottom = rect
+        width = max(right - left, 1)
+        height = max(bottom - top, 1)
+        hint_text = " ".join(hints).casefold()
+        score = 0
+        if control_type == "Button":
+            score += 12
+        elif control_type == "Hyperlink":
+            score += 6
+        elif control_type == "Text":
+            score += 4
+        elif control_type == "Document":
+            score += 3
+        elif control_type == "Pane":
+            score += 2
+
+        tokens = self._dbit_text_tokens([login_tokens])
+        if any(token.casefold() in hint_text for token in tokens):
+            score += 18
+        if any(token in hint_text for token in ("submit", "continue", "next", "go")):
+            score += 6
+        if any(token in hint_text for token in ("register", "sign up", "forgot", "忘记", "注册")):
+            score -= 12
+        if 24 <= height <= 72:
+            score += 4
+        if width >= 100:
+            score += 2
+
+        if password_rect is not None:
+            password_center_x = password_rect[0] + int((password_rect[2] - password_rect[0]) / 2)
+            candidate_center_x = left + int(width / 2)
+            horizontal_delta = abs(candidate_center_x - password_center_x)
+            if horizontal_delta <= 80:
+                score += 5
+            elif horizontal_delta <= 160:
+                score += 2
+            vertical_gap = top - password_rect[3]
+            if 0 <= vertical_gap <= 140:
+                score += 8
+            elif vertical_gap < 0:
+                score -= 8
+        if window_rect is not None:
+            win_left, win_top, win_right, win_bottom = window_rect
+            win_width = max(win_right - win_left, 1)
+            win_height = max(win_bottom - win_top, 1)
+            if left >= win_left + int(win_width * 0.12) and right <= win_right - int(win_width * 0.12):
+                score += 3
+            if top >= win_top + int(win_height * 0.25):
+                score += 2
+        return score
+
