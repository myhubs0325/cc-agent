+    def _connect_window_with_fallback(self, timeout_seconds: float) -> BaseWrapper | None:
+        last_error: Exception | None = None
+        title_patterns = self._title_patterns()
+        deadline = time.monotonic() + max(timeout_seconds, 0.1)
+        hwnd = self._find_window_handle()
+        if hwnd is not None:
+            for backend in self._preferred_backends():
+                try:
+                    from pywinauto import Desktop
+
+                    window = Desktop(backend=backend).window(handle=hwnd).wrapper_object()
+                    if self._is_installer_title(window.window_text()):
+                        continue
+                    return window
+                except Exception as exc:
+                    last_error = exc
+        for backend in self._preferred_backends():
+            for pattern in title_patterns:
+                remaining = deadline - time.monotonic()
+                if remaining <= 0:
+                    break
+                try:
+                    window = self._ui_driver.connect(
+                        pattern,
+                        timeout_seconds=max(min(remaining, timeout_seconds), 0.05),
+                        backend=backend,
+                    )
+                    if self._is_installer_title(window.window_text()):
+                        continue
+                    return window
+                except Exception as exc:
+                    last_error = exc
+        if last_error is not None:
+            raise last_error
+        return None
