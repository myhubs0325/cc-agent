+    def _dbit_neighbor_controls(self, control: BaseWrapper) -> list[BaseWrapper]:
+        neighbors: list[BaseWrapper] = []
+        try:
+            parent = control.parent()
+        except Exception:
+            parent = None
+        if parent is None:
+            return neighbors
+        try:
+            siblings = list(parent.children())
+        except Exception:
+            siblings = []
+        try:
+            children = list(control.children())
+        except Exception:
+            children = []
+        for item in siblings + children + [parent]:
+            if self._dbit_controls_match(item, control):
+                continue
+            neighbors.append(item)
+        return neighbors[:10]
