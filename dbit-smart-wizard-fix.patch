+    def _get_all_instances_via_control_panel(self) -> dict[str, list[dict[str, Any]]]:
+        payload = self._control_panel_request("GET", "/api/get-instances")
+        data = payload.get("data", {})
+        if not isinstance(data, dict):
+            return {"linkedin": [], "facebook": [], "tiktok": []}
+        normalized: dict[str, list[dict[str, Any]]] = {}
+        for key in ("linkedin", "facebook", "tiktok"):
+            bucket = data.get(key, [])
+            normalized[key] = [item for item in bucket if isinstance(item, dict)] if isinstance(bucket, list) else []
+        return normalized
