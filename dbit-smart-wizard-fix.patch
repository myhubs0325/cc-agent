+def _dedupe_paths(paths: Iterable[Path]) -> list[Path]:
+    ordered: list[Path] = []
+    seen: set[str] = set()
+    for path in paths:
+        expanded = path.expanduser()
+        key = str(expanded).casefold()
+        if key in seen:
+            continue
+        seen.add(key)
+        ordered.append(expanded)
+    return ordered
