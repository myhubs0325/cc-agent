+    def _preferred_backends(self) -> list[str]:
+        configured_backend = str(self._config.get("window_backend", "uia")).strip() or "uia"
+        ordered = []
+        if configured_backend == "win32":
+            # DBit 的主要交互面渲染在 WebView2 中，win32 常只能看到壳窗口，
+            # 需要优先使用 uia 才能命中账号/密码/登录等真实控件。
+            ordered.append("uia")
+        ordered.append(configured_backend)
+        for backend in ("win32", "uia"):
+            if backend not in ordered:
+                ordered.append(backend)
+        return ordered
