+    @staticmethod
+    def _set_windows_clipboard_text(value: str) -> bool:
+        try:
+            import ctypes
+        except Exception:
+            return False
+
+        CF_UNICODETEXT = 13
+        GMEM_MOVEABLE = 0x0002
+        kernel32 = ctypes.windll.kernel32
+        user32 = ctypes.windll.user32
+        normalized = str(value or "").replace("\r\n", "\n").replace("\n", "\r\n")
+        buffer = ctypes.create_unicode_buffer(normalized)
+        handle = kernel32.GlobalAlloc(GMEM_MOVEABLE, ctypes.sizeof(buffer))
+        if not handle:
+            return False
+        locked = kernel32.GlobalLock(handle)
+        if not locked:
+            kernel32.GlobalFree(handle)
+            return False
+        try:
+            ctypes.memmove(locked, ctypes.addressof(buffer), ctypes.sizeof(buffer))
+        finally:
+            kernel32.GlobalUnlock(handle)
+        if not user32.OpenClipboard(None):
+            kernel32.GlobalFree(handle)
+            return False
+        try:
+            user32.EmptyClipboard()
+            if not user32.SetClipboardData(CF_UNICODETEXT, handle):
+                kernel32.GlobalFree(handle)
+                return False
+            handle = None
+            return True
+        finally:
+            user32.CloseClipboard()
+
+    def _find_dbit_login_submission_control_by_geometry(
+        self,
+        window: BaseWrapper,
+        flow_step: dict[str, Any],
+        *,
+        max_depth: int,
+        max_nodes: int,
+    ) -> BaseWrapper | None:
+        candidates: list[dict[str, Any]] = []
+        window_rect = self._dbit_control_rect(window)
+        _username_control, password_control = self._find_dbit_login_field_controls(
+            window,
