+        timeout_seconds = float(flow_step.get("post_login_timeout_seconds", max(initial_wait_seconds, 12)))
+        deadline = time.monotonic() + max(timeout_seconds, 0.5)
+        sleep_seconds = min(max(initial_wait_seconds, 0.2), 1.0)
+        while True:
+            if not self._is_login_screen(window, flow_step):
+                return True
+            remaining = deadline - time.monotonic()
+            if remaining <= 0:
+                return False
+            time.sleep(min(sleep_seconds, remaining))
