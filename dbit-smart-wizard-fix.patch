+    def _refresh_control_panel_created_instance(
+        self,
+        platform: str,
+        instance_id: Any,
+        profile_id: str,
+        clone_name: str,
+        *,
+        fallback_instances: dict[str, list[dict[str, Any]]],
+    ) -> dict[str, list[dict[str, Any]]]:
+        normalized_platform = _normalize_platform(platform) or "tiktok"
+        poll_count = max(int(self._config.get("control_panel_instance_refresh_attempts", 3)), 1)
+        poll_interval = min(max(float(self._config.get("control_panel_instance_refresh_interval_seconds", 0.2)), 0.0), 1.0)
+        latest_instances = fallback_instances
+        for attempt in range(poll_count):
+            latest_instances = self._get_all_instances_via_control_panel()
+            bucket = latest_instances.get(normalized_platform, [])
+            instance = self._locate_platform_instance(bucket, instance_id, profile_id, clone_name)
+            if self._instance_has_usable_control_panel_config(instance, normalized_platform):
+                return latest_instances
+            if instance is not None and normalized_platform != "tiktok":
+                return latest_instances
+            if attempt + 1 < poll_count and poll_interval > 0:
+                time.sleep(poll_interval)
+        return latest_instances
+
