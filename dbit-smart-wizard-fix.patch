+def _platform_instance_meta(platform: str, instance_count: int | None) -> dict[str, Any]:
+    normalized = _normalize_platform(platform) or str(platform or "").strip().casefold()
+    data: dict[str, Any] = {"platform": normalized}
+    if instance_count is None:
+        return data
+    data["platform_instance_count"] = instance_count
+    if normalized:
+        data[f"{normalized}_instance_count"] = instance_count
+    return data
