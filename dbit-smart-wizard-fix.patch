+    def _execute_flow_action(
+        self,
+        context: "_FlowContext",
+        action: str,
+        flow_step: dict[str, Any],
+    ) -> tuple[RunStatus, str, dict[str, Any], list[str]]:
+        if action in {"ensure_window", "focus_main_window"}:
+            window, meta = self._frontstage_window_or_control_panel(context)
+            if window is not None:
+                return RunStatus.SUCCEEDED, "\u7a97\u53e3\u5df2\u8fde\u63a5\u3002", {"window_title": window.window_text(), **meta}, []
+            if False and meta.get("control_panel_authorized"):
+                return RunStatus.SUCCEEDED, "DBIt 本地控制面板已授权，可直接按 control panel 模式继续。", meta, []
+            return RunStatus.WAITING_INPUT, self._control_panel_waiting_message(meta), meta, []
+        if action == "auto_login_if_needed":
+            return self._auto_login_if_needed(context, flow_step)
+        if action == "wait_for_password_or_continue":
+            return self._wait_for_password_or_continue(context, flow_step)
+        if action == "open_named_tab":
+            return self._open_named_tab(context, flow_step)
+        if action == "click_named_control":
+            return self._click_named_control(context, flow_step)
+        if action == "wait_for_manual_review":
+            return self._wait_for_manual_review(context, flow_step)
+        if action == "pause":
+            time.sleep(float(flow_step.get("seconds", 1)))
+            return RunStatus.SUCCEEDED, "\u6682\u505c\u5b8c\u6210\u3002", {}, []
+        if action in {"open_search", "fill_query", "submit_search", "open_export", "confirm_scope", "save_file"}:
+            return RunStatus.SUCCEEDED, f"\u4fdd\u7559\u6b65\u9aa4\u5df2\u8df3\u8fc7\uff1a{action}\u3002", {}, []
+        return RunStatus.FAILED, f"\u672a\u652f\u6301\u7684 DBIt flow action: {action}", {}, []
+
+    def _ensure_window(self, context: "_FlowContext") -> BaseWrapper:
+        if context.window is not None:
+            self._ui_driver.focus_window(context.window)
+            return context.window
+
+        initial_error: Exception | None = None
+        try:
+            context.window = self._connect_window_with_fallback(timeout_seconds=2.0)
+        except Exception as exc:
+            initial_error = exc
+            context.window = None
+        if context.window is not None:
+            self._ui_driver.focus_window(context.window)
+            return context.window
+
+        executable_path = self._require_resolved_executable_path()
+        process_was_running = self._is_process_running(Path(executable_path).name)
+        self._signal_or_start_process(executable_path)
+        startup_probe_timeout = (
+            self._existing_process_probe_timeout_seconds
+            if process_was_running
+            else self._frontstage_startup_probe_timeout_seconds
+        )
+        try:
+            context.window = self._connect_window_with_fallback(
+                timeout_seconds=startup_probe_timeout
+            )
+        except Exception as exc:
+            if initial_error is not None:
+                raise ValueError(f"{exc}; initial probe: {initial_error}") from exc
+            raise
+        if context.window is None:
+            raise ValueError("未能连接到 DBit Octopus 主窗口。")
+        self._ui_driver.focus_window(context.window)
+        return context.window
+
+    def _signal_or_start_process(self, executable_path: str | Path) -> None:
+        executable = Path(executable_path).expanduser()
+        startup_wait_seconds = float(self._config.get("startup_wait_seconds", 6))
+        if self._is_process_running(executable.name):
+            # Reuse the existing DBit process instead of spawning duplicate windows.
+            if startup_wait_seconds > 0:
+                time.sleep(min(startup_wait_seconds, 1.0))
+            return
+        self._ui_driver.start_process(str(executable), startup_wait_seconds=startup_wait_seconds)
